// AkaraConnect Phase 3 Prisma schema design.
// Planning artifact only. Do not migrate until Phase 4 is approved.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
  DELETED
}

enum UserRoleName {
  CUSTOMER
  VENDOR
  ADMIN
  SUPER_ADMIN
  RIDER
}

enum VerificationStatus {
  DRAFT
  PENDING
  MORE_INFO_REQUIRED
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  BUSINESS_PHOTO
  ID_CARD
  UTILITY_BILL
  CAC_DOCUMENT
  FOOD_PERMIT
  OTHER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum FulfillmentType {
  PICKUP
  VENDOR_DELIVERY
  PLATFORM_DELIVERY
}

enum DeliveryStatus {
  NOT_REQUIRED
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  MONIEPOINT
  OPAY
  PALMPAY
  VISA
  MASTERCARD
  BANK_TRANSFER
  WALLET
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REVERSAL
  HOLD
  RELEASE
}

enum ReviewModerationStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REPORTED
  REMOVED
}

enum NotificationType {
  ORDER
  PAYMENT
  REVIEW
  VENDOR_VERIFICATION
  SECURITY
  PROMOTION
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum FraudReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
  ESCALATED
}

enum FraudReportType {
  VENDOR
  CUSTOMER
  ORDER
  PAYMENT
  REVIEW
  SECURITY
}

enum AdvertisementStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                 String                   @id @default(cuid())
  email              String?                  @unique
  phone              String?                  @unique
  passwordHash       String?
  name               String
  avatarUrl          String?
  status             UserStatus               @default(PENDING_VERIFICATION)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?
  roles              UserRole[]
  customerProfile    CustomerProfile?
  vendorProfile      VendorProfile?
  adminProfile       AdminProfile?
  refreshTokens      RefreshToken[]
  otpCodes           OtpCode[]
  twoFactorMethods   TwoFactorMethod[]
  languagePreference UserLanguagePreference?
  notifications      Notification[]
  sentMessages       Message[]                @relation("SentMessages")
  callLogs           CallLog[]
  auditLogs          AuditLog[]               @relation("AuditActor")
  securityLogs       SecurityLog[]
  supportTickets     SupportTicket[]

  @@index([status])
  @@index([createdAt])
}

model UserRole {
  id        String       @id @default(cuid())
  userId    String
  role      UserRoleName
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model CustomerProfile {
  id        String     @id @default(cuid())
  userId    String     @unique
  firstName String?
  lastName  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  reviews   Review[]
  favorites Favorite[]
  wallets   Wallet[]
}

model VendorProfile {
  id         String           @id @default(cuid())
  userId     String           @unique
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businesses VendorBusiness[]
}

model AdminProfile {
  id          String     @id @default(cuid())
  userId      String     @unique
  displayName String?
  department  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model OtpCode {
  id         String    @id @default(cuid())
  userId     String?
  phone      String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, purpose, expiresAt])
}

model TwoFactorMethod {
  id          String    @id @default(cuid())
  userId      String
  method      String
  secretHash  String?
  enabledAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, method])
}

model VendorBusiness {
  id                  String                 @id @default(cuid())
  vendorProfileId     String
  businessName        String
  slug                String                 @unique
  ownerName           String
  phone               String
  whatsapp            String?
  email               String?
  description         String?
  logoUrl             String?
  coverPhotoUrl       String?
  openingTime         String?
  closingTime         String?
  verificationStatus  VerificationStatus     @default(DRAFT)
  isOpen              Boolean                @default(false)
  isFeatured          Boolean                @default(false)
  averageRating       Decimal                @default(0) @db.Decimal(3, 2)
  reviewCount         Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?
  vendorProfile       VendorProfile          @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  verification        VendorVerification?
  documents           BusinessDocument[]
  location            VendorLocation?
  photos              VendorBusinessPhoto[]
  deliveryOptions     DeliveryOption[]
  menuItems           MenuItem[]
  orders              Order[]
  reviews             Review[]
  favorites           Favorite[]
  advertisements      Advertisement[]
  subscriptions       VendorSubscription[]
  languagePreferences VendorLanguagePreference[]
  wallets             Wallet[]

  @@index([verificationStatus, isOpen])
  @@index([businessName])
}

model VendorVerification {
  id               String             @id @default(cuid())
  vendorBusinessId String             @unique
  status           VerificationStatus @default(PENDING)
  submittedAt      DateTime?
  reviewedByUserId String?
  reviewedAt       DateTime?
  rejectionReason  String?
  adminNotes       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  vendorBusiness   VendorBusiness     @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@index([status, submittedAt])
}

model BusinessDocument {
  id               String         @id @default(cuid())
  vendorBusinessId String
  type             DocumentType
  fileUrl          String
  publicId         String?
  status           VerificationStatus @default(PENDING)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  vendorBusiness   VendorBusiness @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@index([vendorBusinessId, type])
}

model VendorLocation {
  id               String         @id @default(cuid())
  vendorBusinessId String         @unique
  state            String
  localGovernment  String
  ward             String?
  community        String?
  street           String?
  houseNumber      String?
  latitude         Decimal?       @db.Decimal(10, 7)
  longitude        Decimal?       @db.Decimal(10, 7)
  googlePlaceId    String?
  googleMapsUrl    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  vendorBusiness   VendorBusiness @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@index([state, localGovernment])
  @@index([latitude, longitude])
}

model VendorBusinessPhoto {
  id               String         @id @default(cuid())
  vendorBusinessId String
  imageUrl         String
  publicId         String?
  caption          String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  deletedAt        DateTime?
  vendorBusiness   VendorBusiness @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)
}

model FoodCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  menuItems   MenuItem[]

  @@index([isActive, sortOrder])
}

model MenuItem {
  id               String         @id @default(cuid())
  vendorBusinessId String
  categoryId       String
  name             String
  description      String?
  price            Decimal        @db.Decimal(12, 2)
  isAvailable      Boolean        @default(true)
  preparationTime  Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  vendorBusiness   VendorBusiness @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)
  category         FoodCategory   @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  orderItems       OrderItem[]

  @@index([vendorBusinessId, isAvailable])
  @@index([categoryId, isAvailable])
}

model ProductImage {
  id         String   @id @default(cuid())
  menuItemId String
  imageUrl   String
  publicId   String?
  altText    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  deletedAt  DateTime?
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model DeliveryOption {
  id               String          @id @default(cuid())
  vendorBusinessId String
  type             FulfillmentType
  isEnabled        Boolean         @default(true)
  baseFee          Decimal?        @db.Decimal(12, 2)
  maxDistanceKm    Decimal?        @db.Decimal(8, 2)
  estimatedMinutes Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  vendorBusiness   VendorBusiness  @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@unique([vendorBusinessId, type])
}

model Order {
  id               String             @id @default(cuid())
  orderNumber      String             @unique
  customerId       String
  vendorBusinessId String
  status           OrderStatus        @default(PENDING)
  fulfillmentType  FulfillmentType
  paymentStatus    PaymentStatus      @default(UNPAID)
  subtotal         Decimal            @db.Decimal(12, 2)
  deliveryFee      Decimal            @default(0) @db.Decimal(12, 2)
  serviceFee       Decimal            @default(0) @db.Decimal(12, 2)
  total            Decimal            @db.Decimal(12, 2)
  customerNote     String?
  deliveryAddress  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cancelledAt      DateTime?
  completedAt      DateTime?
  deletedAt        DateTime?
  customer         CustomerProfile    @relation(fields: [customerId], references: [id])
  vendorBusiness   VendorBusiness     @relation(fields: [vendorBusinessId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  statusEvents     OrderStatusEvent[]
  deliveryTracking DeliveryTracking?
  reviews          Review[]

  @@index([customerId, createdAt])
  @@index([vendorBusinessId, status, createdAt])
  @@index([paymentStatus])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  menuItemId     String?
  itemName       String
  unitPrice      Decimal  @db.Decimal(12, 2)
  quantity       Int
  total          Decimal  @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  actorId   String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model DeliveryTracking {
  id               String         @id @default(cuid())
  orderId          String         @unique
  status           DeliveryStatus @default(PENDING)
  riderUserId      String?
  pickupLatitude   Decimal?       @db.Decimal(10, 7)
  pickupLongitude  Decimal?       @db.Decimal(10, 7)
  dropoffLatitude  Decimal?       @db.Decimal(10, 7)
  dropoffLongitude Decimal?       @db.Decimal(10, 7)
  estimatedMinutes Int?
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("NGN")
  providerReference String?         @unique
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds           RefundRequest[]

  @@index([orderId, status])
  @@index([provider, status])
}

model PaymentWebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventType   String
  reference   String?
  payload     Json
  processedAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([provider, reference])
}

model RefundRequest {
  id        String        @id @default(cuid())
  paymentId String
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(12, 2)
  reason    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  payment   Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Wallet {
  id               String          @id @default(cuid())
  userId           String?
  customerId       String?
  vendorBusinessId String?
  currency         String          @default("NGN")
  balance          Decimal         @default(0) @db.Decimal(12, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  customer         CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendorBusiness   VendorBusiness? @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)
  transactions     WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(12, 2)
  reference   String?               @unique
  description String?
  metadata    Json?
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model Review {
  id               String                 @id @default(cuid())
  customerId       String
  vendorBusinessId String
  orderId          String?
  rating           Int
  comment          String?
  moderationStatus ReviewModerationStatus @default(PUBLISHED)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  deletedAt        DateTime?
  customer         CustomerProfile        @relation(fields: [customerId], references: [id])
  vendorBusiness   VendorBusiness         @relation(fields: [vendorBusinessId], references: [id])
  order            Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  images           ReviewImage[]

  @@index([vendorBusinessId, moderationStatus])
  @@index([customerId, createdAt])
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  imageUrl  String
  publicId  String?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Favorite {
  id               String          @id @default(cuid())
  customerId       String
  vendorBusinessId String
  createdAt        DateTime        @default(now())
  customer         CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vendorBusiness   VendorBusiness  @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@unique([customerId, vendorBusinessId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  titleKey  String
  bodyKey   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Conversation {
  id               String    @id @default(cuid())
  customerUserId   String?
  vendorBusinessId String?
  subject          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  messages         Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderUserId   String
  type           MessageType  @default(TEXT)
  body           String?
  mediaUrl       String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderUserId], references: [id])

  @@index([conversationId, createdAt])
}

model CallLog {
  id               String    @id @default(cuid())
  userId            String
  vendorBusinessId  String?
  orderId           String?
  phoneNumberMasked String
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model FraudReport {
  id          String            @id @default(cuid())
  type        FraudReportType
  status      FraudReportStatus @default(OPEN)
  reporterId  String?
  targetId    String?
  title       String
  description String?
  severity    Severity          @default(MEDIUM)
  metadata    Json?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, severity, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  severity  Severity @default(LOW)
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([severity, createdAt])
}

model Advertisement {
  id               String              @id @default(cuid())
  vendorBusinessId String?
  title            String
  imageUrl          String?
  destinationUrl    String?
  placement         String
  status            AdvertisementStatus @default(DRAFT)
  startsAt          DateTime?
  endsAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  vendorBusiness    VendorBusiness?     @relation(fields: [vendorBusinessId], references: [id], onDelete: SetNull)

  @@index([status, placement])
}

model SubscriptionPlan {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  price       Decimal              @db.Decimal(12, 2)
  currency    String               @default("NGN")
  interval    String
  features    Json?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  subscriptions VendorSubscription[]
}

model VendorSubscription {
  id               String             @id @default(cuid())
  vendorBusinessId String
  planId           String
  status           SubscriptionStatus @default(ACTIVE)
  startsAt         DateTime
  endsAt           DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  vendorBusiness   VendorBusiness     @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([vendorBusinessId, status])
}

model UserLanguagePreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  locale    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VendorLanguagePreference {
  id               String         @id @default(cuid())
  vendorBusinessId String
  locale           String
  createdAt        DateTime       @default(now())
  vendorBusiness   VendorBusiness @relation(fields: [vendorBusinessId], references: [id], onDelete: Cascade)

  @@unique([vendorBusinessId, locale])
}

model SupportTicket {
  id          String              @id @default(cuid())
  userId      String?
  status      SupportTicketStatus @default(OPEN)
  subject     String
  description String
  priority    Severity            @default(MEDIUM)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  closedAt    DateTime?
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, priority, createdAt])
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
